{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aweb-wine.vercel.app/specs/aweb-agent-receipt.v0.1.schema.json",
  "title": "Aweb Agent Receipt",
  "description": "Illustrative schema for grant-reviewer examples. This is not yet the final public package contract.",
  "type": "object",
  "required": [
    "receipt_version",
    "receipt_id",
    "example",
    "created_at",
    "scope",
    "authority",
    "agent",
    "workflow",
    "capability",
    "execution",
    "evidence",
    "privacy",
    "review"
  ],
  "properties": {
    "receipt_version": {
      "type": "string",
      "const": "aweb.agent_receipt.v0.1"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 8
    },
    "example": {
      "type": "boolean",
      "const": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "string",
      "enum": [
        "cross_chain",
        "consensus_ordering",
        "movevm_execution",
        "payment_preparation",
        "private_execution",
        "vault_risk_review",
        "durable_workflow",
        "smart_account"
      ]
    },
    "authority": {
      "type": "object",
      "required": [
        "grant_id",
        "mode",
        "authorized_by",
        "allowed_actions",
        "denied_actions"
      ],
      "properties": {
        "grant_id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "observe",
            "simulate",
            "prepare",
            "execute_with_human_approval"
          ]
        },
        "authorized_by": {
          "type": "string"
        },
        "policy_profile": {
          "type": "string"
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "denied_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "agent": {
      "type": "object",
      "required": [
        "agent_id",
        "model_class",
        "operator"
      ],
      "properties": {
        "agent_id": {
          "type": "string"
        },
        "model_class": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "workflow": {
      "type": "object",
      "required": [
        "workflow_id",
        "intent",
        "environment"
      ],
      "properties": {
        "workflow_id": {
          "type": "string"
        },
        "intent": {
          "type": "string"
        },
        "environment": {
          "type": "string",
          "enum": [
            "simulated",
            "testnet",
            "mainnet_read_only",
            "production"
          ]
        }
      },
      "additionalProperties": true
    },
    "capability": {
      "type": "object",
      "required": [
        "provider",
        "tool",
        "category"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "tool": {
          "type": "string"
        },
        "category": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "execution": {
      "type": "object",
      "required": [
        "status",
        "started_at",
        "finished_at",
        "idempotency_key",
        "cost"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "prepared",
            "simulated",
            "succeeded",
            "failed",
            "rejected",
            "needs_human_review"
          ]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        },
        "idempotency_key": {
          "type": "string"
        },
        "cost": {
          "type": "object",
          "required": [
            "amount",
            "unit"
          ],
          "properties": {
            "amount": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "object",
      "required": [
        "summary",
        "artifacts"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "type",
              "ref",
              "redacted"
            ],
            "properties": {
              "type": {
                "type": "string"
              },
              "ref": {
                "type": "string"
              },
              "redacted": {
                "type": "boolean"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "privacy": {
      "type": "object",
      "required": [
        "redaction_policy",
        "redacted_fields"
      ],
      "properties": {
        "redaction_policy": {
          "type": "string"
        },
        "redacted_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "required": [
        "trust_state",
        "human_review_required",
        "review_notes"
      ],
      "properties": {
        "trust_state": {
          "type": "string"
        },
        "human_review_required": {
          "type": "boolean"
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
